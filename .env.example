# GaggiMate Integration App - Environment Variables

# LM Studio (ローカルLLM) — ホストマシンで起動している場合
LM_STUDIO_BASE_URL=http://host.docker.internal:1234/v1
LM_STUDIO_MODEL=local-model

# GaggiMate接続（Docker内ではsimulatorサービス名を使用）
# 実機の場合はここをGaggiMateのIPに変更
# GAGGIMATE_HOST=gaggimate.local
# GAGGIMATE_WS_PORT=8765
